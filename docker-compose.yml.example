services:
  libretranslate:
    image: libretranslate/libretranslate:latest
    container_name: teacher_libretranslate
    restart: unless-stopped
    environment:
      LT_LOAD_ONLY: "es,en"
      LT_DISABLE_WEB_UI: "true"
    volumes:
      - libretranslate_data:/home/libretranslate/.local
    networks: [teacher_net]

  db:
    image: mariadb:11.4
    container_name: teacher_db
    restart: unless-stopped
    env_file:
      - .env
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
      MYSQL_DATABASE: ${DB_NAME}
      MYSQL_USER: ${DB_USER}
      MYSQL_PASSWORD: ${DB_PASSWORD}
    ports:
      - "127.0.0.1:33069:3306"
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - teacher_net
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: teacher_redis
    restart: unless-stopped
    ports:
      - "127.0.0.1:8903:6379"
    networks: [teacher_net]

  backend:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: teacher_backend
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - uploads_data:/app/uploads
    ports:
      - "127.0.0.1:8904:8000"
    networks:
      - teacher_net
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_started

  worker:
    build:
      context: ./backend
      dockerfile: Dockerfile
    container_name: teacher_worker
    restart: unless-stopped
    env_file:
      - .env
    command: celery -A app.worker.celery_app worker --loglevel=info --concurrency=4
    volumes:
      - uploads_data:/app/uploads
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_started
      backend:
        condition: service_started
    networks:
      - teacher_net

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: teacher_frontend
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "127.0.0.1:8905:5173"
    networks:
      - teacher_net
    depends_on:
      - backend

networks:
  teacher_net:
    driver: bridge

volumes:
  db_data:
  uploads_data:
  libretranslate_data:
